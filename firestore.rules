rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid']);
      allow update, delete: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.isAnonymous == true
        && request.resource.data.roomsCount == 0
        && request.resource.data.matchesCount == 0;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.resource.data.id == roomId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members
        && request.resource.data.memberCount == 1
        && request.resource.data.status == "waiting"
        && request.resource.data.category is string
        && request.resource.data.name is string
        && request.resource.data.mood is string
        && request.resource.data.filters is map
        && request.resource.data.currentCardIndex == 0
        && request.resource.data.matches is list
        && request.resource.data.watchlist is list;
      allow update: if request.auth != null && (
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["members", "memberCount"])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.auth.uid in request.resource.data.members
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["name", "mood", "filters"])
          && request.auth.uid in resource.data.members
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["status"])
          && resource.data.createdBy == request.auth.uid
        )
      );
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      match /swipes/{swipeId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
        allow create, update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.movieId is int
          && request.resource.data.action in ["liked", "disliked", "maybe"];
        allow delete: if false;
      }

      match /matches/{matchId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
        allow create, update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members
          && request.resource.data.movieId is int
          && request.resource.data.title is string;
        allow delete: if false;
      }

      match /progress/{userId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members
          && request.resource.data.currentIndex is int;
        allow delete: if false;
      }
    }
  }
}
