rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isRoomMember(roomId) {
      return request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
    }

    function isMovieSwipe(data) {
      return data.itemType == 'movie'
        && data.itemId is string
        && data.movieId is int;
    }

    function isPlaceSwipe(data) {
      return data.itemType == 'place'
        && data.itemId is string;
    }

    function isLegacyMovieSwipe(data) {
      return data.movieId is int
        && !('itemType' in data);
    }

    function isValidSwipe(data) {
      return data.userId is string
        && data.action in ['liked', 'disliked', 'maybe']
        && (isMovieSwipe(data) || isPlaceSwipe(data) || isLegacyMovieSwipe(data));
    }

    function isMovieMatch(data) {
      return (data.itemType == 'movie' || !('itemType' in data))
        && data.movieId is int
        && data.title is string;
    }

    function isPlaceMatch(data) {
      return data.itemType == 'place'
        && data.itemId is string
        && data.title is string;
    }

    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid']);
      allow update, delete: if false;
    }

    match /pushTokens/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.isAnonymous is bool
        && request.resource.data.roomsCount == 0
        && request.resource.data.matchesCount == 0;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /app_config/{docId} {
      // Public read: non-sensitive feature flags (limits, ads toggle).
      allow read: if true;
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.resource.data.id == roomId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members
        && request.resource.data.memberCount == 1
        && request.resource.data.status == "waiting"
        && request.resource.data.category is string
        && request.resource.data.name is string
        && request.resource.data.mood is string
        && request.resource.data.filters is map
        && request.resource.data.currentCardIndex == 0
        && request.resource.data.matches is list
        && request.resource.data.watchlist is list;
      allow update: if request.auth != null && (
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["members", "memberCount"])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.auth.uid in request.resource.data.members
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["name", "mood", "filters"])
          && request.auth.uid in resource.data.members
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["status"])
          && resource.data.createdBy == request.auth.uid
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["movieQueue"])
          && request.auth.uid in resource.data.members
          && request.resource.data.movieQueue is list
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["placeQueue"])
          && request.auth.uid in resource.data.members
          && request.resource.data.placeQueue is list
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["placeCache"])
          && request.auth.uid in resource.data.members
          && request.resource.data.placeCache is map
        )
        ||
        (
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["placeQueue", "placeCache"])
          && request.auth.uid in resource.data.members
          && request.resource.data.placeQueue is list
          && request.resource.data.placeCache is map
        )
      );
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      match /swipes/{swipeId} {
        allow read: if isRoomMember(roomId);
        allow create, update: if isRoomMember(roomId)
          && request.resource.data.userId == request.auth.uid
          && isValidSwipe(request.resource.data);
        allow delete: if false;
      }

      match /matches/{matchId} {
        allow read: if isRoomMember(roomId);
        allow create, update: if isRoomMember(roomId)
          && (isMovieMatch(request.resource.data) || isPlaceMatch(request.resource.data));
        allow delete: if false;
      }

      match /progress/{userId} {
        allow read: if isRoomMember(roomId);
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && isRoomMember(roomId)
          && request.resource.data.currentIndex is int;
        allow delete: if false;
      }
    }
  }
}
