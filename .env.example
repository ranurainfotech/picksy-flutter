# TMDB (required for movie discovery)
# TMDB_ACCESS_TOKEN=

# Monetization (optional — feature flag defaults to off in Firestore)
# Public SDK keys only — never put RevenueCat secret keys (sk_...) in the app.

# RevenueCat — Test Store (no App Store / Play setup yet):
# REVENUECAT_API_KEY=test_...
# Production (per platform, from RevenueCat → Project → API keys):
# REVENUECAT_IOS_API_KEY=appl_...
# REVENUECAT_ANDROID_API_KEY=goog_...

# AdMob — interstitial ad unit IDs (from AdMob → Ad units; format ca-app-pub-XXXX/YYYY)
# App IDs (ca-app-pub-XXXX~YYYY) go in android/app/src/main/AndroidManifest.xml
# and ios/Runner/Info.plist — not in this file.
# ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/NNNNNNNNNN
# ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/NNNNNNNNNN
